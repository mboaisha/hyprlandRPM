{
    "style":"~/.config/waybar/style.css",
    
    "layer": "top",
    "position": "top",
    "height": "40",

    "modules-left": [
        "hyprland/workspaces"
    ],

    "modules-center": [
        "clock"
    ],

    "modules-right": [
        "tray",
        "battery",
        "pulseaudio",
        "network",
        "cpu",
        "memory"

    ],

    "include": "~/.config/waybar/modules.jsonc"

}